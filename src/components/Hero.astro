---
import { mockProfile } from "../data/mockData";
import { translations } from "../data/translations";

const { lang = "es" } = Astro.props;
const t = translations[lang].hero;
---

<section
  id="home"
  class="min-h-screen flex items-center justify-center px-4 pt-20"
>
  <div class="container mx-auto max-w-6xl">
    <div class="text-center">
      <div class="relative inline-block">
        <div class="absolute -inset-4 bg-gradient-to-r from-blue-600 via-sky-500 to-indigo-600 rounded-full blur-2xl opacity-50 animate-pulse"></div>
        <img
          src={mockProfile.avatar}
          alt={mockProfile.name}
          class="relative w-80 h-80 rounded-full mx-auto border-4 border-blue-500/30 shadow-2xl z-10 object-cover object-[50%_25%]"
        />
      </div>

      {/* Title */}
      <h1 class="text-4xl md:text-6xl font-bold mb-4 bg-gradient-to-r from-blue-600 via-sky-500 to-indigo-600 bg-clip-text text-transparent">
        {mockProfile.name}
      </h1>

      <p class="text-xl md:text-2xl text-muted-foreground mb-6">
        {mockProfile.title[lang]}
      </p>

      {/* Info */}
      <div class="flex flex-col sm:flex-row items-center justify-center space-y-2 sm:space-y-0 sm:space-x-6 mb-8">
        <div class="flex items-center space-x-2 text-muted-foreground">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{mockProfile.location}</span>
        </div>
        <div class="flex items-center space-x-2 text-muted-foreground">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span>{mockProfile.email}</span>
        </div>
      </div>

      {/* Bio */}
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto mb-12 leading-relaxed">
        {mockProfile.bio[lang]}
      </p>

      {/* CTA Button */}
      <a
        href="#about"
        class="group inline-flex items-center space-x-2 px-8 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-full hover:from-blue-700 hover:to-indigo-700 transition-all duration-300 transform hover:scale-105 shadow-lg"
      >
        <span>{t.cta}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-down group-hover:translate-y-1 transition-transform"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
      </a>
    </div>
  </div>

  {/* Animated Background */}
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-72 h-72 bg-blue-500/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-indigo-500/15 rounded-full blur-3xl animate-pulse delay-1000"></div>
  </div>
</section>
