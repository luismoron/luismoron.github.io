---
import { timelineEvents } from "../data/mockData";

const { lang = "es" } = Astro.props;
---

<section id="timeline" class="py-20 px-4 bg-muted/10">
  <div class="container mx-auto max-w-4xl">
    <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">
      {lang === "es"
        ? "Línea de Tiempo de mi Carrera"
        : "My Career Timeline"}
    </h2>

    <div class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-primary/20 before:to-transparent">
      {timelineEvents.map((event) => (
        <div class={`relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group ${event.era}`}>
          {/* Icon */}
          <div class="flex items-center justify-center w-10 h-10 rounded-full border border-primary/20 bg-card shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 transition-all duration-300 group-hover:scale-125 group-hover:border-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check-circle-2 text-primary"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          {/* Content Card */}
          <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-card p-6 rounded-xl border border-border shadow-sm transition-all duration-300 group-hover:shadow-md">
            <div class="flex items-center justify-between mb-2">
              <div class="font-bold text-primary text-xl font-mono">
                {event.year}
              </div>
            </div>
            <div class="text-lg font-bold mb-2 group-hover:text-primary transition-colors">
              {event.title[lang]}
            </div>
            <div class="text-muted-foreground">
              {event.description[lang]}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
