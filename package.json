  "private": true,
  "homepage": "https://luismoron.dev",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "astro": "^5.17.1",
    "lucide": "^0.417.0"
  },
  "scripts": {
    "dev": "astro dev",
