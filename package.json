    "gh-pages": "^6.1.1",
    "postcss": "^8.4.39",
    "tailwindcss": "3.4.6",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.4",
    "vite": "^5.3.5"
  },
  "packageManager": "pnpm@10.20.0"
